local function PlayAudio(id, vol)
	local s = Instance.new("Sound")
	s.SoundId = id; s.Volume = vol or 0.5; s.Parent = SoundService
	s:Play(); s.Ended:Connect(function() s:Destroy() end)
end

local function Create(cls, props)
	local i = Instance.new(cls); for k,v in pairs(props) do i[k] = v end; return i
end

local function AnimateBtn(btn)
	btn.MouseEnter:Connect(function() PlayAudio(Sounds.Hover, 0.1); TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Config.Accent}):Play() end)
	btn.MouseLeave:Connect(function() TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Theme.Side}):Play() end)
	btn.MouseButton1Click:Connect(function() PlayAudio(Sounds.Click, 0.5) end)
end

