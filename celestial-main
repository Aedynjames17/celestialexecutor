local function SaveData()
	if writefile then pcall(function() writefile("Celestial_Config.json", HttpService:JSONEncode(Config)) end) end
end

local function LoadData()
	if readfile and isfile and isfile("Celestial_Config.json") then
		pcall(function() 
			local data = HttpService:JSONDecode(readfile("Celestial_Config.json"))
			if data and data.Modules then 
				for _, sm in pairs(data.Modules) do
					for _, cm in pairs(Config.Modules) do if sm.Name == cm.Name then cm.Enabled = sm.Enabled end end
				end
			end
		end)
	end
end
